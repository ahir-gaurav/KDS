# ══════════════════════════════════════════════════════════════════════════════
# VERCEL ENVIRONMENT VARIABLES CHECKLIST
# ══════════════════════════════════════════════════════════════════════════════
# Add each of these in:
# Vercel Dashboard → your project → Settings → Environment Variables
# Make sure to set them for all environments (Production, Preview, Development)
# ══════════════════════════════════════════════════════════════════════════════

# ── Backend API ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
# ↑ Your Render service URL — no trailing slash, no /api/v1 suffix.
# Find it in: Render Dashboard → your web service → Settings → Custom Domains

# ── Clerk Auth ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_key_here
# ↑ Public key — safe to expose, used by the browser.
# Find it in: Clerk Dashboard → your app → API Keys

CLERK_SECRET_KEY=sk_live_your_key_here
# ↑ Secret key — server-side only, NEVER expose in client code.
# Find it in: Clerk Dashboard → your app → API Keys

# ── Razorpay ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_key_id
# ↑ Public key ID — used in the browser to open the Razorpay payment modal.
# Find it in: Razorpay Dashboard → Settings → API Keys

# ══════════════════════════════════════════════════════════════════════════════
# RENDER ENVIRONMENT VARIABLES CHECKLIST (backend)
# ══════════════════════════════════════════════════════════════════════════════
# Add each of these in:
# Render Dashboard → your web service → Environment → Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/kicks-dont-stink
# JWT_SECRET=<generate a long random secret>
# JWT_REFRESH_SECRET=<generate a long random secret>
# CLOUDINARY_CLOUD_NAME=<your cloudinary cloud name>
# CLOUDINARY_API_KEY=<your cloudinary api key>
# CLOUDINARY_API_SECRET=<your cloudinary api secret>
# RAZORPAY_KEY_ID=rzp_live_your_key_id
# RAZORPAY_KEY_SECRET=<your razorpay key secret>
# RAZORPAY_WEBHOOK_SECRET=<your webhook secret>
# ADMIN_SECRET_CODE=<a strong secret for admin registration>
#
# ↓ CRITICAL — must match your actual Vercel deployment URL(s):
# FRONTEND_URL=https://your-app.vercel.app
# ADMIN_URL=https://your-admin.vercel.app
#
# PORT=5000  (Render sets this automatically, you can omit it)
